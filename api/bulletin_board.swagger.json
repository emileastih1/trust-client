{
  "swagger": "2.0",
  "info": {
    "title": "The Bulletin Board for TRUST",
    "description": "Bulletin Board Service",
    "version": "1.0",
    "contact": {
      "name": "TRUST",
      "url": "https://github.com/USTRWG/bulletin-board-api"
    }
  },
  "tags": [
    {
      "name": "BulletinBoardService"
    }
  ],
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check endpoint",
        "description": "This is the health check endpoint",
        "operationId": "BulletinBoardService_Health",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.HealthResponse"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "tags": [
          "BulletinBoardService"
        ]
      }
    },
    "/v1/address_ownership_proofs/{address}": {
      "put": {
        "summary": "Submit a proof of address ownership for a previously claimed (address/chain)",
        "description": "This is the singular endpoint for creating an address ownership proof",
        "operationId": "BulletinBoardService_CreateAddressOwnershipProof",
        "responses": {
          "200": {
            "description": "Create or update proof of address succeeded",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.CreateAddressOwnershipProofResponse"
            }
          },
          "400": {
            "description": "Invalid request. For example, the (address, chain, registration_id) combination is invalid or missing fields.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "409": {
            "description": "Conflicted proof status, e.g., change from non-IOU to IOU",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "parameters": [
          {
            "name": "address",
            "description": "The SHA512 of the blockchain address",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "registrationId": {
                  "type": "string",
                  "description": "The registration UUID when you claimed the address by calling PUT /addresses/\u003caddress\u003e"
                },
                "chain": {
                  "type": "string",
                  "description": "The blockchain of the address, e.g., BITCOIN, ETHEREUM"
                },
                "signature": {
                  "type": "string",
                  "description": "The signature of the proof of ownership message signed by the private key of the address"
                },
                "prefix": {
                  "type": "string",
                  "description": "The prefix of the claiming VASP's choice"
                },
                "iou": {
                  "type": "boolean",
                  "description": "Indicate whether this is an IOU"
                },
                "auxProofData": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/bulletin_board.v1.AuxProofData"
                  },
                  "description": "Additional data supporting the different types of proof of address ownerships, e.g., redeem script. (See Proof of Address Ownership Spec doc for auxiliary data required for all of the supported proof types)"
                },
                "proofType": {
                  "type": "string",
                  "description": "The proof type dictating the logic of proofing and verification according to the spec. Example values: BITCOIN_P2PKH, BITCOIN_P2SH, BITCOIN_P2WPKH, BITCOIN_P2WSH, ETHEREUM_EOA, ETHEREUM_CONTRACT. (See Proof of Address Ownership Spec doc for all the supported proof types)"
                }
              },
              "title": "Create Address Ownership Proof Request"
            }
          }
        ],
        "tags": [
          "BulletinBoardService"
        ]
      }
    },
    "/v1/addresses/{address}": {
      "get": {
        "summary": "Retrieve the custody of an address and the proof of address ownership",
        "description": "This endpoint retrieves the VASP who has custody of an address. You must query with the sha512 hash of the address. Additionally, a proof of ownership (or an IOU) is returned so VASP(S) can self-verify.",
        "operationId": "BulletinBoardService_GetAddressOwnership",
        "responses": {
          "200": {
            "description": "Get address ownership succeeded",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.GetAddressOwnershipResponse"
            }
          },
          "400": {
            "description": "Invalid request, parameter validation failure.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "404": {
            "description": "Address not found",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "parameters": [
          {
            "name": "address",
            "description": "The SHA512 of the blockchain address.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "chain",
            "description": "The blockchain of the address, e.g., BITCOIN, ETHEREUM.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "BulletinBoardService"
        ]
      },
      "delete": {
        "summary": "Delete a Record of Address Custody",
        "description": "This endpoint deletes a record of address custody from your VASP's filter",
        "operationId": "BulletinBoardService_DeleteAddressOwnership",
        "responses": {
          "200": {
            "description": "Delete succeeded",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.DeleteAddressOwnershipResponse"
            }
          },
          "400": {
            "description": "Invalid request, parameter validation failure.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "parameters": [
          {
            "name": "address",
            "description": "The SHA512 of the blockchain address.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "chain",
            "description": "The blockchain of the address, e.g., BITCOIN, ETHEREUM.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "BulletinBoardService"
        ]
      },
      "put": {
        "summary": "Claim custody of an (address/chain)",
        "description": "Claim custody of an (address/chain)",
        "operationId": "BulletinBoardService_CreateAddressOwnership",
        "responses": {
          "200": {
            "description": "Claim address custody succeeded",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.CreateAddressOwnershipResponse"
            }
          },
          "400": {
            "description": "Invalid request, parameter validation failure.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "409": {
            "description": "Conflict (when the address is already claimed by others)",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "parameters": [
          {
            "name": "address",
            "description": "The SHA512 of the blockchain address.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "chain": {
                  "type": "string",
                  "description": "The blockchain of the address, e.g., BITCOIN, ETHEREUM."
                }
              },
              "title": "Create Address Ownership Request"
            }
          }
        ],
        "tags": [
          "BulletinBoardService"
        ]
      }
    },
    "/v1/vasps": {
      "get": {
        "summary": "Retrieve the information of all VASPs",
        "description": "Retrieve the information of all VASPs.",
        "operationId": "BulletinBoardService_GetVasps",
        "responses": {
          "200": {
            "description": "Successfully get the information of all VASPs",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.GetVaspsResponse"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "tags": [
          "BulletinBoardService"
        ]
      }
    },
    "/v1/vasps/{vaspId}": {
      "get": {
        "summary": "Retrieve the information of a specific VASP",
        "description": "This endpoint retrieves the information of a specific VASP.\n\nVASP(S) can query the GET /addresses endpoint to know the VASP(R) who claims the custody of an address.\n\nOnce VASP(S) knows VASP(R)'s identity and verifies the Proof of Address Ownership, it can query this endpoint to know VASP(R)'s PII endpoint. \n\nThe PII information should be encrypted with the VASP(R)'s publicKey using the JOSE spec before being transmitted to VASP(R)'s PII endpoint. \n\n",
        "operationId": "BulletinBoardService_GetVasp",
        "responses": {
          "200": {
            "description": "Successfully retrieve the information of the VASP",
            "schema": {
              "$ref": "#/definitions/bulletin_board.v1.GetVaspResponse"
            }
          },
          "400": {
            "description": "Invalid request, parameter validation failure. For example, the provided vasp id is not a valid UUID",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "403": {
            "description": "Not authorized",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "404": {
            "description": "VASP not found",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "500": {
            "description": "Internal service error",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/google.rpc.Status"
            }
          }
        },
        "parameters": [
          {
            "name": "vaspId",
            "description": "The UUID of the VASP that your are querying for",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "BulletinBoardService"
        ]
      }
    }
  },
  "definitions": {
    "bulletin_board.v1.AddressOwnershipProof": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The registration UUID of the address"
        },
        "address": {
          "type": "string",
          "description": "The SHA512 of the blockchain address"
        },
        "signature": {
          "type": "string",
          "description": "The signature of the proof of ownership message signed by the private key of the address"
        },
        "prefix": {
          "type": "string",
          "description": "The prefix of the claiming VASP's choice"
        },
        "iou": {
          "type": "boolean",
          "description": "Indicate whether this is an IOU"
        },
        "chain": {
          "type": "string",
          "description": "The blockchain of the address, e.g., BITCOIN, ETHEREUM"
        },
        "proofType": {
          "type": "string",
          "description": "The proof type dictating the logic of proofing and verification according to the spec. Example values: BITCOIN_P2PKH, BITCOIN_P2SH, BITCOIN_P2WPKH, BITCOIN_P2WSH, ETHEREUM_EOA, ETHEREUM_CONTRACT. (See Proof of Address Ownership Spec doc for all the supported proof types)"
        },
        "auxProofData": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/bulletin_board.v1.AuxProofData"
          },
          "description": "Additional data supporting the different types of proof of address ownerships, e.g., redeem script. (See Proof of Address Ownership Spec doc for auxiliary data required for all of the supported proof types)"
        }
      },
      "title": "Address Ownership Proof Response Object"
    },
    "bulletin_board.v1.AuxProofData": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Supported AuxProofData type, e.g., ETH_CREATE, ETH_CREATE2, REDEEM_SCRIPT."
        },
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Key-value pairs data. Each type of aux data should come with pre-defined set of parameters. (See See Proof of Address Ownership Spec doc for the data schema) "
        }
      },
      "title": "Aux Proof Data"
    },
    "bulletin_board.v1.CreateAddressOwnershipProofResponse": {
      "type": "object",
      "properties": {
        "registrationId": {
          "type": "string",
          "description": "The created proof of address ownership"
        }
      },
      "title": "Create Address Ownership Proof Response"
    },
    "bulletin_board.v1.CreateAddressOwnershipResponse": {
      "type": "object",
      "properties": {
        "registrationId": {
          "type": "string",
          "description": "The registration UUID associated with this address ownership claim"
        }
      },
      "title": "Create Address Ownership Response"
    },
    "bulletin_board.v1.DeleteAddressOwnershipResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "Detail message indicating the deletion results"
        }
      },
      "title": "Delete Address Ownership Response"
    },
    "bulletin_board.v1.GetAddressOwnershipResponse": {
      "type": "object",
      "properties": {
        "vasp": {
          "$ref": "#/definitions/bulletin_board.v1.VASP",
          "description": "The information of the VASP with custody of the address"
        },
        "addressOwnershipProof": {
          "$ref": "#/definitions/bulletin_board.v1.AddressOwnershipProof",
          "description": "The proof of address ownership submitted by the VASP who claimed the address"
        }
      },
      "title": "Get Address Ownership Response"
    },
    "bulletin_board.v1.GetVaspResponse": {
      "type": "object",
      "properties": {
        "vasp": {
          "$ref": "#/definitions/bulletin_board.v1.VASP",
          "description": "The information of the queried VASP"
        }
      },
      "title": "Get VASP Response"
    },
    "bulletin_board.v1.GetVaspsResponse": {
      "type": "object",
      "properties": {
        "vasps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/bulletin_board.v1.VASP"
          },
          "description": "List of VASP configs in the TRUST solution."
        }
      },
      "title": "Get VASP Response"
    },
    "bulletin_board.v1.HealthResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "title": "Health Response"
    },
    "bulletin_board.v1.VASP": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "VASP UUID in the Bulletin Board config"
        },
        "name": {
          "type": "string",
          "description": "VASP name"
        },
        "domain": {
          "type": "string",
          "description": "The domain is the dNSName in the SAN (Subject Alternative Name) of a VASP's client certificate. This will be used by all other VASPs' P2P channel and the bulletin Board for authentication during the mTLS handshake"
        },
        "piiEndpoint": {
          "type": "string",
          "description": "The endpoint for receiving PII data. This is a full url (host + path) that can be directly used to make the HTTPS API call"
        },
        "piiRequestEndpoint": {
          "type": "string",
          "description": "The endpoint for requesting PII data. This is a full url (host + path) that can be directly used to make the HTTPS API call"
        },
        "publicKey": {
          "type": "string",
          "description": "The public key for other VASPs to encrypt the PII data using the JWE JOSE spec"
        },
        "lei": {
          "type": "string",
          "description": "The Legal Entity Identifier of the VASP"
        },
        "publicKeyVersion": {
          "type": "integer",
          "format": "int32",
          "description": "The version of the public key. Version should be bumped when a VASP rotates and updates its public key"
        },
        "returnAddressEndpoint": {
          "type": "string",
          "description": "The endpoint for returning address. This is a full url (host + path) that can be directly used to make the HTTPS API call"
        },
        "returnFundConfirmationEndpoint": {
          "type": "string",
          "description": "The endpoint for returning fund confirmation. This is a full url (host + path) that can be directly used to make the HTTPS API call"
        }
      },
      "title": "VASP Response Object"
    },
    "google.protobuf.Any": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "google.rpc.Status": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/google.protobuf.Any"
          }
        }
      }
    }
  }
}
